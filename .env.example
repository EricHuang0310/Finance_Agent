# Alpaca API Configuration
# Get your keys at: https://app.alpaca.markets
# Paper trading: no real money needed

ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here
ALPACA_PAPER=true

# Telegram Notifications
# Setup: @BotFather → /newbot → copy token
# Then send a message to your bot and visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: for news sentiment analysis
# FINNHUB_API_KEY=your_finnhub_key
# NEWSAPI_KEY=your_newsapi_key
